# Copy to .env and fill in real values for local development.
# In production, set these as real environment variables (do NOT commit .env).

# Long random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-value

# --- Database ---------------------------------------------------------------
# The app selects its database from DATABASE_URL if set, otherwise it falls
# back to a local SQLite file (DATABASE below).
#
# Postgres (production). Render/Heroku inject DATABASE_URL automatically; the
# app accepts postgres://, postgresql://, or postgresql+psycopg:// forms.
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
#
# SQLite (local dev default). Only used when DATABASE_URL is unset.
DATABASE=users.db

# Port the server listens on (most PaaS platforms set this automatically).
PORT=5000

# Set to 0/false in production. Enables Flask's debugger for `python app.py` only.
FLASK_DEBUG=1
